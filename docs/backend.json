
{
  "entities": {
    "Activity": {
      "title": "Activity",
      "type": "object",
      "description": "Mewakili aktivitas atau tugas yang ingin dilacak oleh pengguna.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Kesehatan", "Kerja", "Belajar", "Lainnya"] },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"], "default": "Medium" },
        "durationMinutes": { "type": "number", "default": 25 },
        "targetValue": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "type": "object",
      "description": "Catatan setiap kali aktivitas diselesaikan.",
      "properties": {
        "id": { "type": "string" },
        "activityId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "activityId", "userId", "date"]
    },
    "Goal": {
      "title": "Goal",
      "type": "object",
      "description": "Target spesifik pengguna (misal: Belajar 20 jam).",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "targetValue": { "type": "number" },
        "currentValue": { "type": "number", "default": 0 },
        "unit": { "type": "string", "enum": ["Jam", "Materi", "Episode"] },
        "deadline": { "type": "string", "format": "date" }
      },
      "required": ["userId", "title", "targetValue", "unit"]
    },
    "Reflection": {
      "title": "Reflection",
      "type": "object",
      "description": "Refleksi harian pengguna.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "shortNote": { "type": "string" },
        "content": { "type": "string" },
        "productivityRating": { "type": "number", "minimum": 1, "maximum": 5 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date"]
    },
    "WatchlistEntry": {
      "title": "WatchlistEntry",
      "type": "object",
      "description": "Entri film atau series yang ditonton pengguna.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "totalEpisodes": { "type": "number" },
        "lastEpisode": { "type": "number" },
        "status": { "type": "string", "enum": ["Watching", "Completed", "Paused"] },
        "lastWatched": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "totalEpisodes", "lastEpisode", "status"]
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "type": "object",
      "description": "Data peringkat pengguna.",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" },
        "level": { "type": "number" },
        "totalActivities": { "type": "number" },
        "currentStreak": { "type": "number" },
        "isBot": { "type": "boolean", "default": false }
      },
      "required": ["username", "level", "totalActivities", "currentStreak"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/activities/{activityId}",
        "definition": {
          "entityName": "Activity",
          "schema": { "$ref": "#/backend/entities/Activity" },
          "description": "Koleksi aktivitas milik pengguna."
        }
      },
      {
        "path": "/users/{userId}/logs/{logId}",
        "definition": {
          "entityName": "ActivityLog",
          "schema": { "$ref": "#/backend/entities/ActivityLog" },
          "description": "Log penyelesaian aktivitas."
        }
      },
      {
        "path": "/users/{userId}/goals/{goalId}",
        "definition": {
          "entityName": "Goal",
          "schema": { "$ref": "#/backend/entities/Goal" },
          "description": "Target belajar spesifik."
        }
      },
      {
        "path": "/users/{userId}/reflections/{reflectionId}",
        "definition": {
          "entityName": "Reflection",
          "schema": { "$ref": "#/backend/entities/Reflection" },
          "description": "Catatan refleksi harian."
        }
      },
      {
        "path": "/users/{userId}/watchlist/{entryId}",
        "definition": {
          "entityName": "WatchlistEntry",
          "schema": { "$ref": "#/backend/entities/WatchlistEntry" },
          "description": "Watchlist film/series pengguna."
        }
      },
      {
        "path": "/leaderboard/{entryId}",
        "definition": {
          "entityName": "LeaderboardEntry",
          "schema": { "$ref": "#/backend/entities/LeaderboardEntry" },
          "description": "Entri leaderboard global."
        }
      }
    ]
  }
}
