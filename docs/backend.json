
{
  "entities": {
    "Activity": {
      "title": "Activity",
      "type": "object",
      "description": "Mewakili aktivitas atau tugas yang ingin dilacak oleh pengguna.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Kesehatan", "Kerja", "Belajar", "Lainnya"] },
        "targetValue": { "type": "number", "description": "Target penyelesaian (misal: 1 kali per hari)" },
        "color": { "type": "string", "description": "Kode warna hex untuk visualisasi" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "targetValue"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "type": "object",
      "description": "Catatan setiap kali aktivitas diselesaikan.",
      "properties": {
        "id": { "type": "string" },
        "activityId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "value": { "type": "number", "description": "Jumlah yang diselesaikan" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "activityId", "userId", "date", "value"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/activities/{activityId}",
        "definition": {
          "entityName": "Activity",
          "schema": { "$ref": "#/backend/entities/Activity" },
          "description": "Koleksi aktivitas milik pengguna tertentu.",
          "params": [
            { "name": "userId", "description": "UID pemilik aktivitas" },
            { "name": "activityId", "description": "ID unik aktivitas" }
          ]
        }
      },
      {
        "path": "/users/{userId}/logs/{logId}",
        "definition": {
          "entityName": "ActivityLog",
          "schema": { "$ref": "#/backend/entities/ActivityLog" },
          "description": "Log penyelesaian aktivitas untuk tracking progres.",
          "params": [
            { "name": "userId", "description": "UID pemilik log" },
            { "name": "logId", "description": "ID unik log" }
          ]
        }
      }
    ]
  }
}
